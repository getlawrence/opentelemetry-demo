# DataDog Environment Configuration
# Copy this to .env and update with your DataDog credentials

# DataDog API Configuration
DD_API_KEY=your_datadog_api_key_here
DD_SITE=datadoghq.com
DD_ENV=development
DD_SERVICE=opentelemetry-demo
DD_VERSION=latest

# DataDog Agent Configuration
DD_AGENT_HOST=datadog-agent
DD_TRACE_AGENT_PORT=8126
DD_DOGSTATSD_PORT=8125

# DataDog Tracing Configuration
DD_TRACE_ENABLED=true
DD_TRACE_ANALYTICS_ENABLED=true
DD_LOGS_INJECTION=true

# DataDog Java Agent Configuration
DD_JAVA_AGENT_VERSION=1.30.0

# DataDog Service Tags
DD_TAGS=env:development,service:opentelemetry-demo,version:latest

# DataDog Sampling Configuration
DD_TRACE_SAMPLE_RATE=1.0
DD_TRACE_RATE_LIMIT=100

# DataDog Logging Configuration
DD_LOGS_ENABLED=true
DD_LOGS_CONFIG_CONTAINER_COLLECT_ALL=true

# DataDog Process Monitoring
DD_PROCESS_AGENT_ENABLED=true

# DataDog Network Monitoring
DD_NETWORK_MONITORING_ENABLED=true

# DataDog Container Monitoring
DD_CONTAINER_MONITORING_ENABLED=true

# DataDog Custom Metrics
DD_CUSTOM_METRICS_ENABLED=true

# DataDog Error Tracking
DD_ERROR_TRACKING_ENABLED=true

# DataDog RUM (Real User Monitoring) - for frontend
DD_RUM_ENABLED=true
DD_RUM_APPLICATION_ID=your_rum_application_id_here
DD_RUM_CLIENT_TOKEN=your_rum_client_token_here

# DataDog Session Replay - for frontend
DD_SESSION_REPLAY_ENABLED=true

# DataDog Synthetic Monitoring
DD_SYNTHETICS_ENABLED=true

# DataDog APM Configuration
DD_APM_ENABLED=true
DD_APM_NON_LOCAL_TRAFFIC=true

# DataDog Database Monitoring
DD_DBM_ENABLED=true

# DataDog Infrastructure Monitoring
DD_INFRASTRUCTURE_MONITORING_ENABLED=true

# DataDog Security Monitoring
DD_SECURITY_MONITORING_ENABLED=true

# DataDog Compliance Monitoring
DD_COMPLIANCE_MONITORING_ENABLED=true

# DataDog Custom Configuration
DD_CUSTOM_CONFIG_ENABLED=true

# DataDog Debug Mode (set to false in production)
DD_DEBUG=false
DD_LOG_LEVEL=info

# DataDog Proxy Configuration (if needed)
# DD_PROXY_HTTP=http://proxy.company.com:8080
# DD_PROXY_HTTPS=https://proxy.company.com:8080
# DD_PROXY_NO_PROXY=localhost,127.0.0.1

# DataDog Custom Tags for Services
DD_SERVICE_TAGS=team:platform,component:microservices,environment:development

# DataDog Custom Metrics Tags
DD_METRICS_TAGS=datacenter:us-east-1,cluster:demo-cluster

# DataDog Custom Log Tags
DD_LOGS_TAGS=application:opentelemetry-demo,team:platform

# DataDog Custom Trace Tags
DD_TRACE_TAGS=service:opentelemetry-demo,version:latest,env:development
